# ── Ultimate Guitar chord provider (educational / local use only) ─────────────
#
# Set VITE_ENABLE_ULTIMATE_PROVIDER=true to enable the UltimateGuitar provider
# in the Discover page.  You must also run a local scraper that exposes a
# GET /tab?url=<encoded-ug-url> endpoint.
#
# Supported scrapers:
#   • joncardasis/ultimate-api  – https://github.com/joncardasis/ultimate-api
#   • Pilfer/ultimate-guitar-scraper – https://github.com/Pilfer/ultimate-guitar-scraper
#
# The provider is disabled by default so the production build remains clean.
#
VITE_ENABLE_ULTIMATE_PROVIDER=false

# URL of your local Ultimate Guitar scraper (default: http://localhost:3001)
# Only used when VITE_ENABLE_ULTIMATE_PROVIDER=true
VITE_UG_SCRAPER_URL=http://localhost:3001
